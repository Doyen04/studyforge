generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Document {
    id        String     @id @default(cuid())
    filename  String
    fileType  String
    rawText   String
    wordCount Int
    createdAt DateTime   @default(now())
    studySets StudySet[]
}

model StudySet {
    id              String           @id @default(cuid())
    documentId      String
    document        Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
    title           String
    createdAt       DateTime         @default(now())
    lastAccessedAt  DateTime         @default(now())
    flashcards      Flashcard[]
    mcqQuestions    McqQuestion[]
    fillInBlanks    FillInBlank[]
    theoryQuestions TheoryQuestion[]
    quizzes         Quiz[]
}

model Flashcard {
    id         String   @id @default(cuid())
    studySetId String
    studySet   StudySet @relation(fields: [studySetId], references: [id], onDelete: Cascade)
    subtopic       String?
    front          String
    back           String
    nextReviewDate DateTime @default(now())
    interval       Int      @default(0)
    easeFactor     Float    @default(2.5)
    repetitions    Int      @default(0)
}

model McqQuestion {
    id           String   @id @default(cuid())
    studySetId   String
    studySet     StudySet @relation(fields: [studySetId], references: [id], onDelete: Cascade)
    subtopic     String?
    question     String
    options      String
    correctIndex Int
    explanation  String
}

model FillInBlank {
    id                String   @id @default(cuid())
    studySetId        String
    studySet          StudySet @relation(fields: [studySetId], references: [id], onDelete: Cascade)
    subtopic          String?
    sentence          String
    answer            String
    acceptableAnswers String
}

model TheoryQuestion {
    id              String   @id @default(cuid())
    studySetId      String
    studySet        StudySet @relation(fields: [studySetId], references: [id], onDelete: Cascade)
    subtopic        String?
    question        String
    referenceAnswer String
    keyPoints       String
}

model Quiz {
    id           String        @id @default(cuid())
    studySetId   String
    studySet     StudySet      @relation(fields: [studySetId], references: [id], onDelete: Cascade)
    title        String
    questionRefs String
    createdAt    DateTime      @default(now())
    attempts     QuizAttempt[]
}

model QuizAttempt {
    id          String    @id @default(cuid())
    quizId      String
    quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
    score       Float
    answers     String
    startedAt   DateTime  @default(now())
    completedAt DateTime?
}
//remember to tie to user
model UserSetting {
    id            String   @id @default("default")
    geminiApiKey  String?
    updatedAt     DateTime @updatedAt
}
